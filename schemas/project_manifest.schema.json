{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://knowledge-engine-orchestrator/schemas/project_manifest.json",
  "title": "Project Manifest",
  "description": "项目专家产出的项目结构与知识点映射数据（v2.8）。由 step-project (order:3) 生成，供教学专家和校验器消费。",
  "type": "object",
  "required": ["domain", "direction", "knowledge_graph_version", "projects", "mappings", "coverage_rate"],
  "properties": {
    "domain": {
      "type": "string",
      "description": "领域名称"
    },
    "direction": {
      "type": "string",
      "description": "方向名称，从 knowledge_graph.json 继承"
    },
    "knowledge_graph_version": {
      "type": "string",
      "description": "引用的知识图谱版本号，用于一致性校验"
    },
    "requirements_profile_version": {
      "type": "string",
      "description": "引用的需求分析版本号（若未引用则省略）"
    },
    "total_projects": {
      "type": "integer",
      "minimum": 1,
      "description": "项目总数"
    },
    "coverage_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "知识点覆盖率百分比，必须为 100"
    },
    "learning_path_narrative": {
      "type": "string",
      "description": "描述项目集如何构成连贯的学习旅程"
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "description": "项目列表",
      "items": {
        "$ref": "#/definitions/Project"
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "description": "知识点-项目映射关系列表",
      "items": {
        "$ref": "#/definitions/Mapping"
      }
    }
  },
  "definitions": {
    "Project": {
      "type": "object",
      "required": ["id", "name", "difficulty", "covered_knowledge_ids", "estimated_hours"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^Proj-\\d{3}$",
          "description": "项目唯一标识，如 Proj-001",
          "examples": ["Proj-001", "Proj-015"]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "项目标准命名"
        },
        "difficulty": {
          "type": "string",
          "enum": ["入门级", "进阶级", "高级"],
          "description": "项目难度等级"
        },
        "estimated_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 40,
          "description": "项目预计完成时间（小时），建议 2~8"
        },
        "description": {
          "type": "string",
          "description": "项目简要描述"
        },
        "structure": {
          "type": "object",
          "description": "项目步骤结构",
          "required": ["background", "core_knowledge", "practice_steps"],
          "properties": {
            "background": {
              "type": "string",
              "minLength": 1,
              "description": "项目背景与解决问题（≥3句话）"
            },
            "core_knowledge": {
              "type": "string",
              "description": "核心知识思想说明"
            },
            "practice_steps": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["step_id", "step_name", "description"],
                "properties": {
                  "step_id": { "type": "string" },
                  "step_name": { "type": "string" },
                  "description": { "type": "string" },
                  "related_knowledge_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[A-Z]{2,5}-\\d{3}$"
                    },
                    "description": "该步骤涉及的知识点 ID 列表"
                  }
                }
              }
            },
            "deviations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["deviation_id", "description"],
                "properties": {
                  "deviation_id": { "type": "string" },
                  "description": { "type": "string", "description": "偏差现象（仅描述，不给解法）" },
                  "related_knowledge_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[A-Z]{2,5}-\\d{3}$"
                    },
                    "description": "关联的知识点 ID 列表（支持交叉知识点偏差）"
                  }
                }
              }
            },
            "acceptance_criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["standard", "quantified_target"],
                "properties": {
                  "knowledge_ids": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[A-Z]{2,5}-\\d{3}$"
                    },
                    "description": "验收涉及的知识点 ID 列表（支持组合知识点验收）"
                  },
                  "standard": { "type": "string", "description": "组合应用标准" },
                  "quantified_target": { "type": "string", "description": "可量化指标，如 准确率>90%" }
                }
              }
            }
          }
        },
        "covered_knowledge_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{2,5}-\\d{3}$"
          },
          "description": "本项目覆盖的知识点 ID 列表"
        },
        "project_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^Proj-\\d{3}$"
          },
          "description": "前置项目 ID 列表（指导学习顺序），无则空数组"
        }
      }
    },
    "Mapping": {
      "type": "object",
      "required": ["knowledge_id", "knowledge_name", "project_id", "project_name", "application_step", "proficiency_requirement"],
      "properties": {
        "knowledge_id": {
          "type": "string",
          "pattern": "^[A-Z]{2,5}-\\d{3}$"
        },
        "knowledge_name": {
          "type": "string"
        },
        "project_id": {
          "type": "string",
          "pattern": "^Proj-\\d{3}$"
        },
        "project_name": {
          "type": "string"
        },
        "application_step": {
          "type": "string",
          "description": "精确到子步骤的应用环节描述，必须包含可操作动词",
          "examples": ["步骤2.1 数据加载与清洗", "步骤3.2 特征工程-异常值检测"]
        },
        "proficiency_requirement": {
          "type": "string",
          "enum": ["了解", "理解", "熟练应用"],
          "description": "掌握要求等级"
        },
        "merged_coverage": {
          "type": "boolean",
          "default": false,
          "description": "是否因知识点过细而合并覆盖，true 时 application_step 需说明具体运用点"
        }
      }
    }
  }
}
