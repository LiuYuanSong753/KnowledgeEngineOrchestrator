{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Knowledge Engine Orchestrator 事件钩子配置。定义 Pipeline 各阶段的事件触发规则。",
  "version": "2.9.0",
  "hooks": [
    {
      "id": "pre-agent-validate",
      "event": "pre_agent_execute",
      "description": "Agent 执行前自动校验上游 JSON 文件存在且符合 Schema",
      "trigger": "before_each_agent",
      "actions": [
        {
          "type": "validate_file_exists",
          "description": "校验上游依赖的 JSON 文件是否存在"
        },
        {
          "type": "validate_json_schema",
          "description": "使用对应 JSON Schema 校验上游产出"
        }
      ],
      "on_failure": "abort_pipeline",
      "enabled": true
    },
    {
      "id": "post-agent-report",
      "event": "post_agent_execute",
      "description": "Agent 执行完成后输出状态通报和下一步提示",
      "trigger": "after_each_agent",
      "actions": [
        {
          "type": "output_status_report",
          "description": "输出 [N/6] 格式的状态报告"
        },
        {
          "type": "update_checkpoint",
          "description": "更新断点续跑缓存状态"
        }
      ],
      "enabled": true
    },
    {
      "id": "post-generate-syntax-check",
      "event": "post_pipeline_complete",
      "description": "全部文档生成后自动执行 Obsidian 语法校验",
      "trigger": "after_pipeline_complete",
      "actions": [
        {
          "type": "run_syntax_check",
          "description": "对全部产出 .md 文件执行规则组 A-H 扫描"
        },
        {
          "type": "auto_fix_syntax",
          "description": "自动修正 🔴 严重语法问题"
        },
        {
          "type": "generate_syntax_report",
          "description": "生成 .shared/syntax_check_report.md"
        }
      ],
      "enabled": true
    },
    {
      "id": "on-agent-error",
      "event": "agent_error",
      "description": "任何 Agent 执行失败时生成错误摘要并记录",
      "trigger": "on_agent_error",
      "actions": [
        {
          "type": "generate_error_summary",
          "description": "生成结构化错误报告，含错误码和详情"
        },
        {
          "type": "save_to_shared",
          "description": "将错误报告保存到 .shared/error_report.json"
        }
      ],
      "on_failure": "continue_pipeline",
      "enabled": true
    },
    {
      "id": "post-coverage-warning",
      "event": "post_verify_low_coverage",
      "description": "闭环校验器发现覆盖率不足时触发警告",
      "trigger": "coverage_below_threshold",
      "threshold": {
        "coverage_rate": 100
      },
      "actions": [
        {
          "type": "output_warning",
          "description": "输出覆盖率警告，列出缺失知识点"
        },
        {
          "type": "mark_verification_failed",
          "description": "标记 verification_result.overall_passed = false"
        }
      ],
      "enabled": true
    }
  ]
}
